# Copy to .env and fill in.

# --- Primary path: Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Free testing path: any OpenAI-compatible endpoint ---
# Uncomment to test without an Anthropic key (defaults target Groq's free
# tier — get a key at https://console.groq.com). Test-the-plumbing mode:
# free models are less reliable at multi-tool calls than Claude.
# LLM_PROVIDER=openai
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
